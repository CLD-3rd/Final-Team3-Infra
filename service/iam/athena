provider "aws" {
  region = "ap-northeast-2"
}

resource "aws_iam_role" "grafana_athena_role" {
  name = "grafana-athena-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Effect = "Allow"
      Principal = {
        Service = "grafana.amazonaws.com"  # Grafana가 AWS 역할을 맡을 경우 서비스 이름, 필요하면 수정
        # 혹은 "ec2.amazonaws.com" 등 환경에 맞게 변경
      }
      Action = "sts:AssumeRole"
    }]
  })
}

resource "aws_iam_policy" "grafana_athena_policy" {
  name        = "grafana-athena-policy"
  description = "Athena + Glue read permissions for Grafana"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "athena:GetWorkGroup",
          "athena:StartQueryExecution",
          "athena:GetQueryResults",
          "athena:GetQueryExecution",
          "athena:ListWorkGroups"
        ]
        Resource = "*"
      },
      {
        Effect = "Allow"
        Action = [
          "glue:GetDatabase",
          "glue:GetDatabases",
          "glue:GetTable",
          "glue:GetTables"
        ]
        Resource = "arn:aws:glue:ap-northeast-2:061039804626:catalog"
      },
      {
        Effect = "Allow"
        Action = [
          "s3:GetObject",
          "s3:PutObject",
          "s3:GetBucketLocation"
        ]
        Resource = [
          "arn:aws:s3:::your-athena-query-results-bucket/*",
          "arn:aws:s3:::your-cloudfront-logs-bucket/*"
        ]
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "attach_policy" {
  role       = aws_iam_role.grafana_athena_role.name
  policy_arn = aws_iam_policy.grafana_athena_policy.arn
}